{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/data.js": { "maxDuration": 20 },
    "api/notify.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/data?product=power535&warm=1", "schedule": "30 6 * * *" },
    { "path": "/api/notify", "schedule": "30 15 * * *" }
  ]
}
